@page "/orders"
@inject CustomerPortal.Data.OrderApiService ApiService

<h3>My Orders</h3>

@if (_loading)
{
    <p>Loading orders...</p>
}
else if (_orders.Count == 0)
{
    <p>No orders found. <a href="/products">Start shopping</a></p>
}
else
{
    <table style="width: 100%; border-collapse: collapse;">
        <thead>
        <tr>
            <th>Order ID</th>
            <th>Date</th>
            <th>Total</th>
            <th>Status</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var order in _orders)
        {
            <tr>
                <td>@order.Id.ToString()[..8]...</td>
                <td>@order.CreatedAt.ToShortDateString()</td>
                <td>€@order.TotalAmount</td>
                <td>@order.Status</td>
                <td><a href="/order-tracking/@order.Id">Track</a></td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private List<CustomerPortal.Data.OrderDto> _orders = new();
    private bool _loading = true;
    private Guid _customerId = Guid.Parse("3fa85f64-5717-4562-b3fc-2c963f66afa6");

    protected override async Task OnInitializedAsync()
    {
        _orders = await ApiService.GetCustomerOrdersAsync(_customerId);
        _loading = false;
    }
}