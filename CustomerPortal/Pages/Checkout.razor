@page "/checkout"
@inject CustomerPortal.Data.CartService CartService
@inject CustomerPortal.Data.OrderApiService ApiService
@inject NavigationManager Navigation

<h3>Checkout</h3>

@if (!CartService.Items.Any())
{
    <p>Your cart is empty. <a href="/products">Browse products</a></p>
}
else
{
    <div style="max-width: 500px;">
        <div>
            <label>Name</label>
            <input @bind="_name" style="width: 100%; margin-bottom: 8px;" />
        </div>
        <div>
            <label>Email</label>
            <input @bind="_email" style="width: 100%; margin-bottom: 8px;" />
        </div>
        <div>
            <label>Shipping Address</label>
            <input @bind="_address" style="width: 100%; margin-bottom: 8px;" />
        </div>

        <h4>Order Summary</h4>
        @foreach (var item in CartService.Items)
        {
            <p>@item.ProductName x@item.Quantity — €@(item.UnitPrice * item.Quantity)</p>
        }
        <h4>Total: €@CartService.Total</h4>

        @if (_error != null)
        {
            <p style="color: red;">@_error</p>
        }

        <button @onclick="PlaceOrder" disabled="@_processing">
            @(_processing ? "Placing order..." : "Place Order")
        </button>
    </div>
}

@code {
    private string _name = string.Empty;
    private string _email = string.Empty;
    private string _address = string.Empty;
    private bool _processing = false;
    private string? _error;

    private async Task PlaceOrder()
    {
        if (string.IsNullOrWhiteSpace(_name) || string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_address))
        {
            _error = "Please fill in all fields.";
            return;
        }

        _processing = true;
        _error = null;

        var request = new CustomerPortal.Data.CheckoutRequest
        {
            CustomerId = Guid.NewGuid(),
            CustomerName = _name,
            CustomerEmail = _email,
            ShippingAddress = _address,
            Items = CartService.Items.Select(i => new CustomerPortal.Data.CartItemDto
            {
                ProductId = i.ProductId,
                ProductName = i.ProductName,
                Quantity = i.Quantity,
                UnitPrice = i.UnitPrice
            }).ToList()
        };

        var orderId = await ApiService.CheckoutAsync(request);

        if (orderId.HasValue)
        {
            CartService.Clear();
            Navigation.NavigateTo($"/order-confirmation/{orderId}");
        }
        else
        {
            _error = "Failed to place order. Please try again.";
            _processing = false;
        }
    }
}